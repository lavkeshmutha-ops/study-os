// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  fullName  String
  email     String   @unique
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  programs AcademicProgram[] @relation("UserPrograms")
}

model Semester {
  id String @id @default(cuid())

  name         String
  number       Int
  academicYear String?

  startDate DateTime
  endDate   DateTime

  isActive Boolean @default(false)

  programId String
  program   AcademicProgram @relation(fields: [programId], references: [id])

  subjects Subject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subject {
  id          String  @id @default(cuid())
  name        String
  code        String?
  description String?
  color       String?

  semesterId String
  semester   Semester @relation(fields: [semesterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AcademicProgram {
  id String @id @default(cuid())

  // Basic Information
  name           String // Diploma, B.Tech, BCA
  specialization String? // CSE, IT, Mechanical
  college        String?

  totalSemesters Int

  // Status
  isActive Boolean @default(true)

  // Relationships
  userId    String
  user      User       @relation("UserPrograms", fields: [userId], references: [id])
  semesters Semester[]

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
