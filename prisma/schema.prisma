generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String            @id @default(cuid())
  clerkId   String            @unique
  fullName  String
  email     String            @unique
  imageUrl  String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  programs  AcademicProgram[] @relation("UserPrograms")
}

model Semester {
  id           String          @id @default(cuid())
  name         String
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  academicYear String?
  number       Int
  programId    String
  program      AcademicProgram @relation(fields: [programId], references: [id])
  subjects     Subject[]
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String?
  description String?
  color       String?
  semesterId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  credits     Int?
  instructor  String?
  isElective  Boolean  @default(false)
  semester    Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  knowledgeNodes KnowledgeNode[]
  lectures    Lecture[]
}

model AcademicProgram {
  id             String     @id @default(cuid())
  name           String
  specialization String?
  college        String?
  totalSemesters Int
  isActive       Boolean    @default(true)
  userId         String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation("UserPrograms", fields: [userId], references: [id])
  semesters      Semester[]
}

enum NodeType {
  COURSE
  UNIT
  CHAPTER
  TOPIC
  SUBTOPIC
  CONCEPT
}

model KnowledgeNode {
  id          String          @id @default(cuid())
  title       String
  slug        String
  description String?
  nodeType    NodeType
  order       Int             @default(0)
  subjectId   String
  parentId    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  subject     Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parent      KnowledgeNode?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    KnowledgeNode[] @relation("NodeHierarchy")
  lectures    Lecture[]
  
  @@unique([subjectId, slug])
}

enum LectureStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Lecture {
  id              String          @id @default(cuid())
  title           String
  date            DateTime
  subjectId       String
  knowledgeNodeId String?
  status          LectureStatus   @default(SCHEDULED)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  subject         Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  knowledgeNode   KnowledgeNode?  @relation(fields: [knowledgeNodeId], references: [id], onDelete: SetNull)
}
